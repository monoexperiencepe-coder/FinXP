# Plantilla: copia como "api/.env" o configura en Vercel (Settings → Environment Variables).
# Nunca commitear valores reales. El token y el verify los sacás de Meta Developer.

# String que TÚ inventás; el mismo va en el campo "Verify token" al suscribir el webhook
VERIFY_TOKEN=

# Token de la API (Graph): WhatsApp → API Setup → "Temporary" o token permanente del System User
WHATSAPP_TOKEN=

# "Phone number ID" (no el número con +51): en la app de Meta, pestaña API de WhatsApp
PHONE_NUMBER_ID=

# Supabase
SUPABASE_URL=
SUPABASE_ANON_KEY=
# Vinculación (whatsapp.js + whatsapp-link-code.js); service role solo en servidor
SUPABASE_SERVICE_ROLE_KEY=

# Número del bot en wa.me, solo dígitos, internacional sin + (ej. 519998887766)
WHATSAPP_BOT_NUMBER=
